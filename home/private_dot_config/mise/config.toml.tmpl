[settings]
disable_tools = ['python']
# Forbid backends that run arbitrary install scripts (asdf, vfox) or fetch
# binaries with no checksum recipe (ubi); resolution is forced through aqua/core.
# dotnet is unused. A tool needing these must opt in with an explicit prefix.
disable_backends = ["asdf", "ubi", "vfox", "dotnet"]
experimental = true
not_found_auto_install = false
idiomatic_version_file_enable_tools = []

# Supply-chain baking time: never install a release younger than this, even for
# tools floated at 'latest'. This is the "delay" layer of pin/delay/vet/audit.
minimum_release_age = "3d"

# Record resolved versions + checksums in a lockfile (~/.config/mise/mise.lock)
# so tools floated at 'latest' don't silently drift between installs, and every
# re-install is checksum-verified against what was first resolved.
lockfile = true

# Verify GPG signatures when a backend publishes them. aqua already does
# checksum + attestation verification; this covers tools that ship a GPG sig.
gpg_verify = true

# Trust this repo's own mise.toml (the dev toolchain for working on dotfiles)
# so cd-ing into the source dir doesn't prompt for trust on every machine.
trusted_config_paths = ["~/.local/share/chezmoi"]

# Install pipx-backed tools via uv (uvx) instead of pip; faster and matches our uv-first setup.
[settings.pipx]
uvx = true

# Use mise's prebuilt ruby (verified download) instead of compiling from source.
[settings.ruby]
compile = false

# Registry of available tools: https://mise.jdx.dev/registry.html
[tools]
# Languages & runtimes
bun = ['latest']
go = ['latest']
node = ['24', '22', 'latest']
pnpm = ['latest']
ruby = ['latest']
rust = ['latest']

# CLI tools, floated at 'latest' (low-risk fast-movers; the apt version lags far
# behind upstream or apt doesn't carry them; minimum_release_age bakes each).
entireio-cli = ['latest']  # tier-2: entireio org includes GitHub CEO (ashtom); fast-moving, floating is defensible
just = ['latest']
usage = ['latest']     # required for mise shell completions
eza = ['latest']       # modern ls replacement (eza-community)
fd = ['latest']        # find replacement; apt also ships it under the name `fdfind` (sharkdp)
fzf = ['latest']       # fuzzy finder (junegunn)
gh = ['latest']        # GitHub CLI (cli/cli)
glow = ['latest']      # render markdown on the CLI (charmbracelet)
starship = ['latest']  # prompt (starship/starship)
"github:yt-dlp/yt-dlp" = { version = "latest", bin = "yt-dlp", minimum_release_age = "3d" }  # Downloader

# AI coding agents, pinned in .chezmoidata.yaml (bump via Renovate PRs + TLDR).
# Moved off ad-hoc `npm install -g` / the claude.ai curl installer; the justfiles
# keep only auth/plugin/config recipes. aqua backends verify checksum +
# attestation; gemini and pi are npm-only. claude is pinned here so it no longer
# self-updates (DISABLE_AUTOUPDATER in ~/.claude/settings.json).
"aqua:anthropics/claude-code" = ['{{ .coding_agents.claude }}']
"aqua:openai/codex" = ['{{ .coding_agents.codex }}']
"aqua:github/copilot-cli" = ['{{ .coding_agents.copilot }}']
"aqua:anomalyco/opencode" = ['{{ .coding_agents.opencode }}']
"npm:@google/gemini-cli" = ['{{ .coding_agents.gemini }}']
"npm:@earendil-works/pi-coding-agent" = ['{{ .coding_agents.pi }}']

# Agent tooling (not agents themselves), pinned so each binary installs from the
# same release as its skill external (.chezmoiexternal.toml.tmpl, worktrunk pattern).
"npm:agent-browser" = ['{{ .tools.agent_browser }}']
"npm:sentry" = ['{{ .tools.sentry }}']  # npm `sentry` (getsentry/cli); NOT aqua sentry-cli, which is a different tool

# CLI tools, pinned in .chezmoidata.yaml (audited; bump via Renovate PRs, see renovate.json)
dust = ['{{ .tools.dust }}']
worktrunk = ['{{ .tools.worktrunk }}']
ast-grep = ['{{ .tools.ast_grep }}']
prek = ['{{ .tools.prek }}']  # pre-commit reimplemented in Rust (j178); drop-in pre-commit replacement
"github:microsoft/apm" = { version = '{{ .tools.apm }}' }  # Agent Package Manager (Microsoft)
# RTK (Rust Token Killer): local CLI-output compressor. On MANUAL trial only for
# now; the auto-rewrite Claude Code hook is deliberately NOT wired yet. Run `rtk
# <cmd>` by hand (e.g. `rtk git status`, `rtk gain`) to feel out the compression.
"aqua:rtk-ai/rtk" = ['{{ .tools.rtk }}']

[tasks.bootstrap]
description = "Bootstrap our CLI"
run = "mise upgrade"

[user]
	name = {{ .name }}
	email = {{ .email }}
	signingkey = {{ .chezmoi.homeDir }}/.ssh/id_ed_25519_signing.pub

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
	program = "/opt/1Password/op-ssh-sign"

[tag]
	forceSignAnnotated = true
	sort = version:refname

[commit]
	gpgsign = true
	verbose = true

[help]
	autoCorrect = immediate

[alias]

	# resolves to main or master depending on the repo
	default-branch = "!git rev-parse --verify refs/heads/main >/dev/null 2>&1 && echo main || echo master"

	ll 	= log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat

	cleanbranches = !git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -d
	cleanbranchesforrealsy = !git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -D

	updm = "!git checkout $(git default-branch) && git pull && git checkout - && git merge --ff-only $(git default-branch)"
	rebm = "!git checkout $(git default-branch) && git pull && git checkout - && git rebase $(git default-branch)"

	# commonly used
	a = add
	ab = absorb
	b = branch
	c = commit
	ca = commit --amend
	cane = commit --amend --no-edit
	cf = commit --fixup
	cl = clone
	cm = commit --message
	co = checkout
	cob = checkout -b
	com = "!git checkout $(git default-branch)"
	cp = cherry-pick
	d = diff
	dc = diff --cached
	fo = fetch origin
	l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	mff = merge --ff-only
	p = push
	pf = push --force-with-lease
	r = restore
	remv = remote -v
	ri = rebase --interactive
	rom = "!git rebase origin/$(git default-branch)"
	rl = reflog
	s = status -sb
	stp = stash push --include-untracked --message
	wd = diff --patience --word-diff

	# rarely used
	ap = add -p                            # Stage individual hunks interactively
	amc = am --continue                    # Resume applying a mailbox patch series
	bm = branch --merged                   # List branches already merged into current
	bnm = branch --no-merged               # List branches not yet merged into current
	dom = "!git diff origin/$(git default-branch)"  # Compare working tree against origin's default branch
	fu = "!git log -n 16 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"  # Fzf-pick a recent commit and create a fixup for it
	lfol = log --follow --                 # Show log for a file, following renames
	incoming = "!git fetch && git log --oneline ..@{u}"  # Show commits on remote that you don't have locally
	ol = log --pretty=oneline              # Compact one-line-per-commit log
	prb = pull --rebase                    # Pull and rebase local commits on top
	ra = rebase --abort                    # Bail out of a rebase in progress
	rc = rebase --continue                 # Continue after resolving rebase conflicts
	rpo = remote prune origin              # Remove local refs to deleted remote branches
	sh = "!git log -n 16 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git show"  # Fzf-pick a recent commit and show its diff
	su = submodule update                  # Pull latest for all submodules


[branch]
	sort = -committerdate

[color]
	ui = auto

[column]
	ui = auto

[core]
	autocrlf = false
	eol = LF
	fileMode = false
  {{ if not .headless -}}
	editor = code --profile /tmp -w -n
  {{ else }}
  editor = emacs
  {{ end -}}

[diff]
	algorithm = histogram
	mnemonicPrefix = true
	renamelimit = 8192
	renames = copies

[fetch]
	fsckobjects = false
	prune = true
	pruneTags = true
	all = true

[init]
	templatedir = ~/.config/git/template
	defaultBranch = master

[absorb]
	maxStack = 20

[push]
	default = current
	autoSetupRemote = true
	followTags = true

[rebase]
	autosquash = true
	autostash = true
	updateRefs = true

[rerere]
	enabled = true
	autoupdate = true

[receive]
	fsckobjects = true

[transfer]
	fsckobjects = true

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

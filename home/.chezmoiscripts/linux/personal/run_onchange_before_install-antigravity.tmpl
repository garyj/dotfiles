{{ if and (eq .chezmoi.arch "amd64") (not .headless) (not .ephemeral) -}}
#!/usr/bin/env bash

if command -v antigravity >/dev/null 2>&1; then
  echo "Google Antigravity is already installed"
  exit 0
fi

# Reference: https://antigravity.google/download/linux

curl -fsSL https://us-central1-apt.pkg.dev/doc/repo-signing-key.gpg | \
	gpg --dearmor | sudo tee /usr/share/keyrings/antigravity-repo-key.gpg > /dev/null

echo "deb [arch=amd64 signed-by=/usr/share/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" | \
	sudo tee /etc/apt/sources.list.d/antigravity.list > /dev/null

sudo apt-get update && sudo apt-get install -y antigravity
{{ end -}}

{{ if and (eq .chezmoi.arch "amd64") (not .headless) (not .ephemeral) .personal -}}
{{ if or (eq .osid "linux-ubuntu") (eq .osid "linux-linuxmint") -}}
#!/usr/bin/env bash

# Handy: free, offline speech-to-text (local Whisper/Parakeet; WisprFlow-style).
# Installed from the pinned GitHub release .deb; apt then resolves its
# dependencies (libgtk-layer-shell0, appindicator, webkit2gtk).
# Bump the pin in .chezmoidata.yaml (deb_apps.handy) to upgrade.
# Reference: https://github.com/cjpais/Handy

set -euo pipefail

version="{{ .deb_apps.handy.version }}"
url="https://github.com/cjpais/Handy/releases/download/v${version}/Handy_${version}_amd64.deb"

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
deb="${tmp}/handy_${version}_amd64.deb"

echo "Downloading Handy ${version}..."
curl -fsSL -o "$deb" "$url"

# apt resolves and installs the .deb's declared dependencies from the configured repos.
sudo apt-get update
sudo apt-get install -y "$deb"

# Runtime libs the .deb fails to declare: libopenblas0 backs the local
# Whisper/Parakeet inference (libopenblas.so.0); xdotool is the X11 backend
# Handy uses to type transcriptions into the focused window.
sudo apt-get install -y libopenblas0 xdotool
{{ end -}}
{{ end -}}

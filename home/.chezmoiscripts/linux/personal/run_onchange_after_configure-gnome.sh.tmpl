    'panel1:right:3:temperature@fevimu:18',
    'panel1:right:4:scale@cinnamon.org:16',
    'panel1:right:5:workspace-switcher@cinnamon.org:15',
    'panel1:right:6:systray@cinnamon.org:3',
    'panel1:right:7:xapp-status@cinnamon.org:4',
    'panel1:right:8:notifications@cinnamon.org:5',
    'panel1:right:9:printers@cinnamon.org:6',
    'panel1:right:10:removable-drives@cinnamon.org:7',
    'panel1:right:11:keyboard@cinnamon.org:8',
    'panel1:right:12:favorites@cinnamon.org:9',
    'panel1:right:13:network@cinnamon.org:10',
    'panel1:right:14:sound@cinnamon.org:11',

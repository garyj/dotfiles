{{ if and (eq .chezmoi.arch "amd64") (not .headless) (not .ephemeral) -}}
#!/usr/bin/env bash

echo -- Running run_onchange_after_configure-gnome.sh.tmpl --

set -eufo pipefail

fc-cache

# Detect desktop environment at runtime
DE="${XDG_CURRENT_DESKTOP:-unknown}"
DE_LOWER=$(echo "$DE" | tr '[:upper:]' '[:lower:]')

is_cinnamon() { [[ "$DE_LOWER" == *"cinnamon"* ]]; }

echo "Detected desktop environment: $DE"


# =============================================================================
# Common Settings (applied regardless of desktop environment)
# =============================================================================

# Dark theme
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

# Also tell the xapp portal (xdg-desktop-portal-xapp) — this is what Chrome,
# Electron, and libadwaita apps read via org.freedesktop.portal.Settings on
# Cinnamon, where x-cinnamon-portals.conf lists xapp before gtk.
if gsettings list-schemas | grep -qx org.x.apps.portal; then
  gsettings set org.x.apps.portal color-scheme 'prefer-dark'
fi

# Disable IBus's built-in emoji hotkey entirely. Its emojier never renders a
# picker window outside GNOME Shell, so <Super>period/<Super>semicolon just
# swallowed keystrokes into a dead annotation preedit (and injected a stray
# glyph). We keep <Super>period as the emoji key (matches the stock default,
# so muscle memory carries across machines) but drive it with Smile, bound
# below, instead of the broken IBus emojier.
if gsettings list-schemas | grep -qx org.freedesktop.ibus.panel.emoji; then
  gsettings set org.freedesktop.ibus.panel.emoji hotkey "@as []"
fi

# Window focus and raising
gsettings set org.gnome.desktop.wm.preferences num-workspaces 9
gsettings set org.gnome.desktop.wm.preferences auto-raise true
gsettings set org.gnome.desktop.wm.preferences auto-raise-delay 500
gsettings set org.gnome.desktop.wm.preferences focus-mode 'sloppy'
gsettings set org.gnome.desktop.wm.preferences focus-new-windows 'smart'
gsettings set org.gnome.desktop.wm.preferences raise-on-click true

# Resize with right button (Super+RightClick)
gsettings set org.gnome.desktop.wm.preferences resize-with-right-button true
gsettings set org.gnome.desktop.wm.preferences mouse-button-modifier '<Super>'

# gnome-terminal settings
if gsettings list-schemas | grep -q org.gnome.Terminal.Legacy.Settings; then
  gsettings set org.gnome.Terminal.Legacy.Settings default-show-menubar true
  profile=$(gsettings get org.gnome.Terminal.ProfilesList default | tr -d "'")
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ background-color 'rgb(23,20,33)'
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ default-size-columns 100
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ default-size-rows 20
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ font 'Fira Code 14'
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ foreground-color 'rgb(208,207,204)'
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ preserve-working-directory 'always'
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ custom-command ''
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ use-custom-command false
  gsettings set org.gnome.Terminal.Legacy.Profile:/org/gnome/terminal/legacy/profiles:/:${profile}/ use-system-font false
fi



{{ if eq .osid "linux-debian" "linux-raspbian" "linux-ubuntu" "linux-linuxmint" -}}

{{ $packages := list
  "curl"
  "eza"
  "zoxide"
-}}

{{ if eq .osid "linux-debian" "linux-ubuntu" "linux-linuxmint" -}}
  {{   $packages = mustAppend $packages "btop" -}}
{{ end -}}

{{ if .personal -}}
  {{  $packages = concat $packages (list
    "ack"
    "apache2-utils"
    "apt-transport-https"
    "bat"
    "build-essential"
    "bubblewrap"
    "bzip2"
    "ca-certificates"
    "clang"
    "direnv"
    "emacs-nox"
    "fd-find"
    "ffmpeg"
    "fzf"
    "gdal-bin"
    "gdu"
    "gh"
    "ghostscript"
    "git-absorb"
    "git-lfs"
    "git"
    "imagemagick"
    "inotify-tools"
    "iotop"
    "jq"
    "libfuse2"
    "locate"
    "nmap"
    "openssh-server"
    "pdftk-java"
    "poppler-utils"
    "python3-dev"
    "ripgrep"
    "shellcheck"
    "smartmontools"
    "sysstat"
    "socat"
    "sshfs"
    "tmux"
    "units"
    "whois"
    "wireguard"
    "wl-clipboard"
    "wmctrl"
    "wtype"
    "zsh"
  )
  -}}
{{ end -}}

{{ if .personal -}}
  {{  $packages = concat $packages (list
    "libpq-dev"
    "fonts-firacode"
  )
  -}}
{{ end -}}

{{ if (and (.personal) (not .headless)) -}}
    {{  $packages = concat $packages (list
      "dconf-editor"
      "flameshot"
      "gimp"
      "gnome-clocks"
      "gparted"
      "gvfs-backends"
      "meld"
      "remmina-plugin-rdp"
      "remmina-plugin-secret"
      "remmina-plugin-vnc*"
      "remmina"
      "samba"
      "vlc"
      "xclip"
    )
  -}}
  {{ if eq .osid "linux-debian" -}}
      {{  $packages = concat $packages (list
        "chromium"
        "gnome-screenshot"
        "gnome-shell-extensions"
        "swappy"
      ) -}}
  {{ else -}}
    {{  $packages = concat $packages (list "chromium-browser" ) -}}
  {{ end -}}
{{ end -}}

#!/usr/bin/env bash

set -euo pipefail

# Create the keyrings dir in case it does not exist
sudo  install -m 0755 -d /etc/apt/keyrings

echo --- Deb Packages: {{ $packages }} ---

sudo apt-get update
sudo apt-get install {{ $packages | join " " }} -y

{{ end }}

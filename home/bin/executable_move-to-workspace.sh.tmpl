{{ if and (not .headless) (not .ephemeral) -}}
#!/usr/bin/env bash
# Move the focused window to a workspace without following it.
# Usage: move-to-workspace.sh <workspace-number>
# Workspace numbers are 1-based (converted to 0-based for D-Bus call).

TARGET=$1

if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  gdbus call --session \
    --dest org.garyj.WindowTools \
    --object-path /org/garyj/WindowTools \
    --method org.garyj.WindowTools.MoveToWorkspace $(($TARGET - 1)) \
    > /dev/null 2>&1
else
  wmctrl -r :ACTIVE: -t $(($TARGET - 1))
fi
{{ end }}

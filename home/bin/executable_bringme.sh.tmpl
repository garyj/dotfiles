{{ if not .headless -}}
#!/usr/bin/env bash
# Bring a window to focus by title, or launch the command if not found.
# Usage: bringme.sh WINDOW_NAME COMMAND
#
# X11 only (wmctrl).

WINDOW_NAME=$1
COMMAND=$2

# --- X11 (wmctrl) ------------------------------------------------------------

bring_x11() {
  local search="$1"
  local matches
  # -lx adds WM_CLASS to the output so the substring match can hit either
  # the window title or the class (e.g. "ChromiumAI"). Class is set once at
  # launch and never changes, making class-based matches bulletproof.
  matches=($(wmctrl -lx | awk -v pat="$search" 'tolower($0) ~ tolower(pat) {print $1}'))

  if [ "${#matches[@]}" = "0" ]; then
    return 1
  else
    wmctrl -i -R "${matches[0]}"
    return 0
  fi
}

# --- Main ---------------------------------------------------------------------

bring_x11 "$WINDOW_NAME" || bash -c "$COMMAND" &
{{ end }}

set dotenv-load := false
set export := true
set quiet := true
set unstable := true

export JUST_UNSTABLE := "true"

mod backup '.justfiles/backup.justfile'
mod claude '.justfiles/claude.justfile'
mod mise '.justfiles/mise.justfile'
mod sentry '.justfiles/sentry.justfile'

HOST := `hostname -s`

[private]
@default:
    just --list --list-submodules

# Setup mise
[group("setup")]
@bootstrap:
    just mise::bootstrap

# Install everything on a new machine (mise + all CLIs; agent skills + configs come from `chezmoi apply`)
[group("setup")]
@install:
    just mise::bootstrap
    for f in .justfiles/[!_]*.justfile; do echo "\033[1;36m>>> Installing from $f\033[0m"; just -f "$f" install || true; done

# Install Playwright browsers + system deps for agent-browser (once per machine; prompts for sudo)
[group("agents")]
@agent-browser-deps:
    agent-browser install --with-deps

# Show Claude Code token usage (ccusage)
[group("agents")]
@claude-usage:
    bunx ccusage@latest

# Show Codex token usage (ccusage)
[group("agents")]
@codex-usage:
    bunx @ccusage/codex@latest

# Upgrade all tools (uv and mise, and all justfiles)
[group("maintenance")]
@upgrade:
    chezmoi upgrade
    uv self update
    uv tool upgrade --all
    just mise::upgrade
    for f in .justfiles/[!_]*.justfile; do echo "\033[1;36m>>> Running upgrade for $f\033[0m"; just -f "$f" upgrade || true; done

# Format and overwrite justfile
[group("utils")]
@fmt:
    just --fmt --unstable
    for f in .justfiles/[!_]*.justfile; do just --fmt --unstable -f "$f"; done


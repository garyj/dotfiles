mongostart() {
  docker run --rm \
    --name mongo \
    --hostname mongo \
    --user "$(id -u):$(id -g)" \
    --ulimit nofile=64000:64000 \
    -p 27017:27017 \
    -v $HOME/.docker_servers_data/mongo:/data/db \
    -d mongodb/mongodb-community-server:{{ .langs.mongodb }}-ubuntu2204
}

mongostop() {
  docker stop $(docker ps -q --filter ancestor=mongodb/mongodb-community-server)
}

# Container for MongoDB Shell Access
moishell() {
  docker run -it --rm \
    --name mongo_shell \
    --user "$(id -u):$(id -g)" \
    --ulimit nofile=64000:64000 \
    --entrypoint /bin/bash \
    mongodb/mongodb-community-server:{{ .langs.mongodb }}-ubuntu2204
}
